# Set to "production" in deployed environments. In production the app refuses
# to start unless SECRET_KEY is a strong (>=32 char) non-default value.
ENVIRONMENT=development
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_crm
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-this-to-a-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=gemma2-9b-it
BACKEND_CORS_ORIGINS=https://hcp-crm-assignment-sandy.vercel.app
